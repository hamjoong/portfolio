          +portfolio-item('portfolioModal1', '../../public/img/matrixcalculator.png', 'Matrix Calculator', 'col-md-6.col-lg-4.mb-5')
          
          // 포트폴리오 아이템 2
          +portfolio-item('portfolioModal2', '../../public/img/kiosk.png', 'Kiosk', 'col-md-6.col-lg-4.mb-5')
          
