        // 헤드 Avatar Image
        img.masthead-avatar.mb-5(src='../../public/img/blog2.png' alt='blog2')
        // 헤드 Heading
        h1.masthead-heading.text-uppercase.mb-0 함중욱
        // 아이콘 구분선 영역
        .divider-custom.divider-light
          .divider-custom-line
          .divider-custom-icon
            i.fas.fa-star
          .divider-custom-line
        // 헤드 Subheading
        p.masthead-subheading.font-weight-light.mb-0 가공되지 않은 원석 Developer 
          br
          | 성실, 열정으로 열심히 하겠습니다
